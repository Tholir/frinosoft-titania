# Database
DATABASE_URL="postgresql://user:password@localhost:5432/titania"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
ENCRYPTION_KEY="generate-with-openssl-rand-base64-32"

# S3 Storage
S3_BUCKET="titania-assets"
S3_REGION="us-east-1"
S3_KEY=""
S3_SECRET=""

# API Keys (system-level, NOT user keys)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
MINIMAX_API_KEY=""

# App
CORS_ORIGIN="http://localhost:3000"
PORT="3001"
NODE_ENV="development"
